{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>chalharu/renovate-config"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "renovate",
      "security"
    ]
  },
  "packageRules": [
    {
      "description": "Give each target version or digest its own Renovate branch so merge gating ages updates independently",
      "matchUpdateTypes": [
        "digest",
        "major",
        "minor",
        "patch",
        "pin",
        "pinDigest"
      ],
      "branchTopic": "{{{depNameSanitized}}}{{#if newVersion}}-{{{newVersion}}}{{/if}}{{#if newDigestShort}}-{{{newDigestShort}}}{{/if}}"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update renovate-version in the Renovate workflow",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/renovate\\.ya?ml$/"
      ],
      "matchStrings": [
        "(?:^|\\n)\\s+renovate-version:\\s*['\"]?(?<currentValue>[^\\s'\"]+)['\"]?\\s*(?:\\n|$)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/renovatebot/renovate",
      "versioningTemplate": "docker"
    }
  ]
}
